[Unit]
Description=Painel de acoes - a cada 15min no pregao + fechamento

[Timer]
# Pregao: seg-sex 10:00-17:45, a cada 15 min
OnCalendar=Mon..Fri *-*-* 10..17:00/15:00
# Snapshot pos-fechamento
OnCalendar=Mon..Fri *-*-* 18:05:00
# Ao ligar o PC, roda a que ficou perdida
Persistent=true

[Install]
WantedBy=timers.target
